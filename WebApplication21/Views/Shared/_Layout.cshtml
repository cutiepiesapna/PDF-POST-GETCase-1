<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplication21</title>
    <script type="importmap"></script>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication21.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="gov-header">
        <div class="top-bar">
            <div class="container d-flex justify-content-between align-items-center">
                <div class="logo-section d-flex align-items-center">
                    <img src="~/css/clear_emblem.png" alt="Logo" class="logo" />
                    <div class="title">
                        <h5>GOVERNMENT OF JAMMU AND KASHMIR</h5>
                        <h3>REVENUE DEPARTMENT</h3>
                    </div>
                </div>

                <div class="right-logos">
                    <img src="~/css/roshinij.jpg" class="mini-logo" />
                    <img src="~/css/swach-bharat.png" class="mini-logo" />
                </div>
            </div>
        </div>

        <nav class="navbar navbar-expand-lg navbar-dark custom-nav">
            <div class="container">
                <a class="navbar-brand" href="#">🏠</a>

                <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    ☰
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav">

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                About Us
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Pdf" asp-action="VandM">
                                        Vision And Mission
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Pdf" asp-action="Org">
                                        Organization
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                Core Services
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Pdf" asp-action="ViewPdf" asp-route-id="5">ROR Status</a></li>
                                <li><a class="dropdown-item" asp-controller="Pdf" asp-action="ViewPdf" asp-route-id="3">Public Services</a></li>
                                <li><a class="dropdown-item" asp-controller="Pdf" asp-action="ViewPdf" asp-route-id="3">Schemes</a></li>
                                <li><a class="dropdown-item" asp-controller="Pdf" asp-action="ViewPdf" asp-route-id="4">Works</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#">E-Compendium</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Pdf" asp-action="ViewPdf" asp-route-id="3">Patwar Service</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Pdf" asp-action="AandR">
                                Acts & Rules
                            </a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="gov-footer">

        <!-- Top Logo Slider Section -->
        <div class="footer-logos">
            <button class="nav-btn">&#10094;</button>

            <div class="logo-container">
                <img src="~/images/e-gazette.png" alt="ECI">
                    <img src="~/images/eci.png" alt="eGazette">
                        <img src="~/images/incredible-india.png" alt="GOI Directory">
                            <img src="~/images/india-gov.png" alt="MyGov">
                                <img src="~/images/mygov.png" alt="Grievance">
                                    <img src="~/images/open-data2.png" alt="NVS">
                                    </div>

                                    <button class="nav-btn">&#10095;</button>
                                </div>

                                <!-- Links Section -->
                                <div class="footer-links">
                                    <a href="#">Feedback</a>
                                    <a href="#">Website Policies</a>
                                    <a href="#">Contact Us</a>
                                    <a href="#">Web Information Manager</a>
                                    <a href="#">FAQ's</a>
                                    <a href="#">Disclaimer</a>
                                    <a href="#">Help</a>
                                    <a href="#">Terms & Conditions</a>
                                </div>

                                <!-- Bottom Info -->
                                <div class="footer-bottom">
                                    <p>
                                        Website Content Managed by <strong>Department Name, Ministry Name, Government of India</strong><br />
                                        Designed, Developed and Hosted by <strong>National Informatics Centre (NIC)</strong>
                                    </p>
                                    <p>Last Updated: April 16, 2026</p>
                                </div>

                            </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
