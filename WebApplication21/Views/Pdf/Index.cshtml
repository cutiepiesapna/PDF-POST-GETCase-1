@model List<WebApplication21.Models.PdfDocument>

<h2>PDF Documents</h2>

<a href="/Pdf/Upload">Upload New PDF</a>

<table border="1">
    <tr>
        <th>File Name</th>
        <th>Download</th>
    </tr>

    @if (Model != null)
    {
        foreach (var file in Model)
        {
            <tr>
                <td>@file.FileName</td>
                <td>
                    <a href="/Pdf/Download/@file.Id">Download</a>
                </td>
            </tr>
        }
    }

</table>